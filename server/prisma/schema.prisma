generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  passwordHash String
  role         String         @default("USER")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  trips        Trip[]
  refreshTokens RefreshToken[]
}

model Trip {
  id             String   @id @default(cuid())
  userId         String
  startLine      String
  endLine        String
  startStation   String
  endStation     String
  stationsCount  Int
  estimatedTime  String
  fares          String
  route          String
  transferGuide  String?
  transferStation String?
  status         String   @default("planned")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model RefreshToken {
  id        String   @id
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model MetroLine {
  id         String        @id
  label      String
  routeLabel String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  stations   MetroStation[]
}

model MetroStation {
  id        String    @id @default(cuid())
  lineId    String
  name      String
  sortOrder Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  line MetroLine @relation(fields: [lineId], references: [id], onDelete: Cascade)

  @@index([lineId, sortOrder])
  @@unique([lineId, name])
}

model FareBand {
  id           String   @id @default(cuid())
  distance     String
  minStations  Int
  maxStations  Int
  ticket       String
  elderly      String
  specialNeeds String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([minStations, maxStations])
}
